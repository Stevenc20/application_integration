SA --> UC32
SA --> UC33
SA --> UC34
SA --> UC35
SA --> UC37

' ===================================================
' RELASI AKTOR KANAN --> USE CASE
' ===================================================
PPS --> UC10
PPS --> UC11
PPS --> UC12
PPS --> UC13
PPS --> UC14
PPS --> UC15
PPS --> UC16

IRM --> UC17
IRM --> UC18
IRM --> UC19
IRM --> UC20
IRM --> UC21
IRM --> UC22
IRM --> UC23
IRM --> UC24

LOG --> UC25
LOG --> UC26
LOG --> UC27
LOG --> UC28

QL --> UC29
QL --> UC30
QL --> UC31

MGR --> UC2
KDV --> UC2
DIR --> UC2
PD --> UC2

DS --> UC28
PS --> UC28

' ===================================================
' EXTEND / INCLUDE
' ===================================================
UC1 ..> UC4 : <<extend>>
UC1 ..> UC3 : <<extend>>
UC1 ..> UC8 : <<extend>>
UC12 ..> UC10 : <<include>>
UC9 ..> UC1 : <<include>>

@enduml
